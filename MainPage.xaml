<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P2PChat.MainPage"
             Title="P2P Chat">

    <Grid RowDefinitions="0.1*, 0.7*, 0.2*"
          ColumnDefinitions="0.1*, 0.7*, 0.2*">

        <!-- Верхняя панель -->
        <Button x:Name="btnConnect" Text="Подключить!"
                Grid.Row="0" Grid.Column="0"
                HorizontalOptions="FillAndExpand" Margin="10"
                Clicked="OnConnectClicked" />
        
        <HorizontalStackLayout VerticalOptions="Center" 
                               Grid.Row="0" Grid.Column="1"
                               HorizontalOptions="StartAndExpand"
                               Spacing="10">
            <HorizontalStackLayout.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnUPnPChecked" NumberOfTapsRequired="1" />
            </HorizontalStackLayout.GestureRecognizers>
            <CheckBox x:Name="chkUPnP" 
                      HorizontalOptions="End"
                      VerticalOptions="Center" 
                      CheckedChanged="OnUPnPChecked"/>

            <Label Text="Использовать UPnP"
                   HorizontalOptions="Start"
                    VerticalOptions="Center">
                
            </Label>
        </HorizontalStackLayout>
        <!-- Список клиентов -->
        <ListView x:Name="lstClients"
                  Grid.Row="1" Grid.Column="2"
                  Margin="0,10,17,10"
                  BackgroundColor="Blue"
                  ItemSelected="OnClientSelected" />

        <!-- Текстовое поле лога -->
        <ScrollView Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="10,10,0,10">
            <Editor x:Name="txtResults"
                    IsReadOnly="True"
                    FontSize="10.667"
                    BackgroundColor="Green"
                    AutoSize="TextChanges" />
        </ScrollView>

        <!-- Нижняя панель -->
            <Button x:Name="btnClear" Text="Очистить"
                    Grid.Column="0" Grid.Row="2"
                    Clicked="OnClearClicked"
                    HorizontalOptions="FillAndExpand" Margin="10,0,0,10" />

        <Button x:Name="btnConnectClient" Text="Подключиться"
                    Grid.Column="2" Grid.Row="2"
                    Clicked="OnConnectClientClicked"
                    IsEnabled="False"
                    HorizontalOptions="FillAndExpand" Margin="0,0,17,10" />
        <StackLayout Grid.Column="1" Grid.Row="2" BackgroundColor="Black" HorizontalOptions="FillAndExpand">
            <Label x:Name="lblName" Text="Имя:" />
            <Label x:Name="lblUPnP" Text="UPnP:" />
            <Label x:Name="lblExtEP" Text="ExtEP:" />
            <Label x:Name="lblIntEP" Text="IntP:" />
            <Label x:Name="lblConType" Text="CT:" />
            <Label x:Name="lblIPs" Text="IPs:" />
        </StackLayout>
    </Grid>
</ContentPage>